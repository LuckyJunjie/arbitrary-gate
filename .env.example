# ============================================================
# arbitrary-gate 环境变量配置示例
# 复制此文件为 .env 后修改实际值
# ============================================================

# ── MySQL ──────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
MYSQL_PORT=3306

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_PORT=6379

# ── Ports ──────────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=80

# ── Alibaba DashScope (通义千问) AI API ────────────────────
# 申请地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ── 内容安全 (阿里云内容安全) ────────────────────────────────
# 如不需要可设置为 false
CONTENT_SAFETY_ENABLED=true
CONTENT_SAFETY_API_KEY=your-content-safety-api-key-here

# ── 微信 JSSDK (可选) ───────────────────────────────────────
# 如不使用微信分享功能可留空
WECHAT_APP_ID=
WECHAT_APP_SECRET=
