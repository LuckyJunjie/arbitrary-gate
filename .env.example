# ============================================================
# MySQL Configuration
# ============================================================
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_USER=appuser
MYSQL_PASSWORD=your_app_password_here
MYSQL_PORT=3306

# ============================================================
# Redis Configuration
# ============================================================
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# ============================================================
# Backend Configuration
# ============================================================
BACKEND_PORT=8080

# ============================================================
# DashScope AI API (Alibaba TongYi Qianwen)
# ============================================================
DASHSCOPE_API_KEY=your_dashscope_api_key_here
CONTENT_SAFETY_ENABLED=true
CONTENT_SAFETY_API_KEY=your_content_safety_api_key_here

# ============================================================
# WeChat Configuration (optional)
# ============================================================
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# WeChat Merchant Configuration (U-05 墨晶充值)
WX_PAY_APP_ID=${WECHAT_APP_ID}
WX_PAY_MCH_ID=your_wechat_merchant_id
WX_PAY_API_KEY=your_wechat_api_key
WX_PAY_NOTIFY_URL=https://your-domain.com/api/pay/wx-callback
WX_PAY_CERT_PATH=/path/to/apiclient_key.pem

# ============================================================
# Aliyun SMS Configuration (U-02)
# ============================================================
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=时光笺
ALIYUN_SMS_TEMPLATE_CODE=SMS_464190095

# ============================================================
# Frontend Configuration
# ============================================================
FRONTEND_PORT=80
